              "pm.collectionVariables.set('dynamic_name', name);\r",
              "console.log('Nombre generado:', name);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status es 201 Created', function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test('El nombre devuelto es el que enviamos', function () {\r",
              "    const enviado = pm.collectionVariables.get('dynamic_name');\r",
              "    pm.expect(pm.response.json().name).to.eql(enviado);\r",
              "});"
